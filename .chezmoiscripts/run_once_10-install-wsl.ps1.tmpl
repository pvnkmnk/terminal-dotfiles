#Requires -Version 7.0
# run_once_10-install-wsl.ps1.tmpl
# Installs WSL2 + Ubuntu-24.04 if not already present
# run_once: idempotent check via wsl --list
# Only runs on Windows — skipped automatically on Linux/WSL

{{- if ne .chezmoi.os "windows" }}
exit 0
{{- end }}

$wslList = wsl --list --quiet 2>$null
if ($wslList -match "Ubuntu") {
    Write-Host "   WSL Ubuntu already installed, skipping."
    exit 0
}

Write-Host "-> Installing WSL2 with Ubuntu-24.04..."
wsl --install -d Ubuntu-24.04

Write-Host ""
Write-Host "[OK] WSL2 + Ubuntu-24.04 installed."
Write-Host ""
Write-Host "NEXT: Open Ubuntu from Start Menu to complete initial user setup."
Write-Host "Then run inside WSL:"
Write-Host "  chezmoi init --apply pvnkmnk"
Write-Host ""
Write-Host "This triggers run_once_11-bootstrap-wsl.sh automatically,"
Write-Host "which installs tools and clones repos onto the WSL ext4 filesystem."
