// dot_config/zellij/config.kdl
// Zellij core configuration - Zellij 0.44+
// Destination: ~/.config/zellij/config.kdl
//
// KEY REFERENCE:
// ---------------------------------------------------------------
// Alt+Left/Right/Up/Down  Move pane focus
// Ctrl+p then d/r         Open pane (down/right split)
// Ctrl+p then x           Close pane
// Ctrl+p then f           Float/embed pane toggle
// Alt+n                   New pane
// Ctrl+o then d           Detach session
// Ctrl+q                  Quit Zellij
// See full docs: https://zellij.dev/documentation/keybindings
// ---------------------------------------------------------------

keybinds {
    normal {
        bind "Alt Left"  { MoveFocus "Left"; }
        bind "Alt Right" { MoveFocus "Right"; }
        bind "Alt Up"    { MoveFocus "Up"; }
        bind "Alt Down"  { MoveFocus "Down"; }
    }
    shared_except "locked" {
        unbind "Ctrl q"
        unbind "Ctrl o"
        bind "Alt t" { Run "tv" { floating true; }; }
    }
}
copy_clipboard "primary"

// zjstatus plugin - pinned to v0.19.1
// Binary fetched automatically via .chezmoiexternal.toml on chezmoi apply
plugins {
    tab-bar location="zellij:tab-bar"
    status-bar location="file:~/.config/zellij/plugins/zjstatus.wasm" {
        format_left  "{mode} #[fg=#89B4FA,bold]{session}"
        format_right "{tabs}"
        hide_frame_for_single_pane "true"
    }
}

theme "catppuccin-mocha"
pane_frames false
simplified_ui true
session_serialization true
auto_layout true
