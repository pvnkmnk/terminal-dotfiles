// dot_config/zellij/layouts/default.kdl
// Default dev workspace layout
// Destination: ~/.config/zellij/layouts/default.kdl
// Launch: Start-DevSession -Project default

layout {
    pane split_direction="vertical" {
        // Left pane: Helix editor, starts in project root
        pane command="hx" {
            size "60%"
            cwd "/projects"
        }
        // Right pane: tooling stack
        pane split_direction="horizontal" {
            pane command="lazygit" {
                cwd "/projects"
            }
            pane command="opencode"
            // Log tail - absolute path avoids ambiguity
            // Adjust to your project's actual log file
            pane command="tail" args="-f" "$HOME/projects/logs/app.log" {
                start_suspended true
            }
        }
    }
    pane size=2 borderless=true {
        plugin location="file:~/.config/zellij/plugins/zjstatus.wasm" {}
    }
}
