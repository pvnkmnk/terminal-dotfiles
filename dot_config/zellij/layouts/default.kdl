// dot_config/zellij/layouts/default.kdl
// Default dev workspace layout
// Destination: ~/.config/zellij/layouts/default.kdl
// Launch: Start-DevSession -Project default

layout {
    pane split_direction="vertical" {
        // Left pane: Helix editor, inherits working directory
        pane command="hx" {
            size "60%"
        }
        // Right pane: tooling stack
        pane split_direction="horizontal" {
            pane command="lazygit"
            pane command="opencode"
            // Log tail — starts suspended, assumes standard logs folder in project
            pane command="tail" {
                args "-f" "logs/app.log"
                start_suspended true
            }
        }
    }
    pane size=2 borderless=true {
        plugin location="status-bar"
    }
}
